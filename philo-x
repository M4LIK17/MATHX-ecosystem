document.addEventListener('DOMContentLoaded', function() {
  var mascote = document.getElementById('mascote');
  if (!mascote) return;

  var pupilLeft = document.getElementById('pupil-left');
  var pupilRight = document.getElementById('pupil-right');
  
  var targetX = window.innerWidth / 2;
  var targetY = window.innerHeight / 2;
  var isHappy = false;
  
  function updateMascote() {
    var dx = (targetX - window.innerWidth / 2) * 0.03;
    var dy = (targetY - window.innerHeight / 2) * 0.03;
    
    if (pupilLeft && pupilRight) {
      pupilLeft.style.transform = 'translate(calc(-50% + ' + dx + 'px), calc(-50% + ' + dy + 'px))';
      pupilRight.style.transform = 'translate(calc(-50% + ' + dx + 'px), calc(-50% + ' + dy + 'px))';
    }
    requestAnimationFrame(updateMascote);
  }
  
  document.addEventListener('mousemove', function(e) {
    targetX = e.clientX;
    targetY = e.clientY;
  });
  
  document.addEventListener('touchmove', function(e) {
    var touch = e.touches[0];
    if (touch) {
      targetX = touch.clientX;
      targetY = touch.clientY;
    }
  }, { passive: true });
  
  document.addEventListener('click', function() {
    if (!isHappy) {
      mascote.classList.add('happy');
      isHappy = true;
      mascote.style.transform = 'scale(1.2)';
      setTimeout(function() {
        mascote.style.transform = 'scale(1)';
        setTimeout(function() {
          mascote.classList.remove('happy');
          isHappy = false;
        }, 600);
      }, 150);
    }
  });
  
  document.addEventListener('touchstart', function() {
    if (!isHappy) {
      mascote.classList.add('happy');
      isHappy = true;
      mascote.style.transform = 'scale(1.2)';
      setTimeout(function() {
        mascote.style.transform = 'scale(1)';
        setTimeout(function() {
          mascote.classList.remove('happy');
          isHappy = false;
        }, 600);
      }, 150);
    }
  }, { passive: true });
  
  updateMascote();
});
  </script>
