<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PHILO-X — Filosofia Interativa</title>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    /* ═══════════════════════════════════════════
       PHILO-X — ESTILOS COMPLETOS
       Paleta: Roxo (#9b6bff) + Dourado (#ffd700)
    ═══════════════════════════════════════════ */

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0d0a14;
      color: #f0ecf5;
      min-height: 100vh;
      overflow-x: hidden;
    }

    :root {
      --philo-bg: #0d0a14;
      --philo-card: #191528;
      --philo-border: #3d2a5c;
      --philo-purple: #9b6bff;
      --philo-gold: #ffd700;
      --philo-cream: #f0ecf5;
      --philo-muted: #8a7a9a;
      --philo-error: #ff6b6b;
      --philo-shadow: rgba(155, 107, 255, 0.15);
    }

    body.light-mode {
      --philo-bg: #f0ecf5;
      --philo-card: #ffffff;
      --philo-border: #c8b8d8;
      --philo-cream: #1a142a;
      --philo-muted: #7a6a8a;
      --philo-shadow: rgba(155, 107, 255, 0.1);
    }

    ::-webkit-scrollbar {
      width: 6px;
      background: var(--philo-bg);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--philo-border);
      border-radius: 999px;
    }

    .app-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 2rem 4rem;
      position: relative;
      min-height: 100vh;
    }

    /* HEADER */
    .philo-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 0 1.5rem;
      border-bottom: 2px solid var(--philo-border);
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .philo-header-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .philo-header-left i {
      font-size: 2.2rem;
      color: var(--philo-gold);
    }

    .philo-header-left h1 {
      font-size: 1.8rem;
      color: var(--philo-purple);
      font-weight: 700;
      letter-spacing: 1px;
    }

    .philo-header-left h1 span {
      color: var(--philo-gold);
    }

    .philo-header .badge {
      background: var(--philo-border);
      color: var(--philo-gold);
      padding: 0.2rem 0.8rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    .header-actions button {
      background: none;
      border: none;
      color: var(--philo-cream);
      font-size: 1.2rem;
      cursor: pointer;
      padding: 0.4rem;
      border-radius: 8px;
      transition: all 0.3s ease;
      border: 1px solid transparent;
    }

    .header-actions button:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--philo-border);
    }

    /* SEARCH */
    .search-bar {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      max-width: 500px;
    }

    .search-bar input {
      flex: 1;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      border: 1px solid var(--philo-border);
      background: var(--philo-card);
      color: var(--philo-cream);
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.3s ease;
    }

    .search-bar input:focus {
      border-color: var(--philo-purple);
    }

    .search-bar input::placeholder {
      color: var(--philo-muted);
    }

    .search-bar button {
      padding: 0.6rem 1.2rem;
      background: var(--philo-purple);
      border: none;
      border-radius: 8px;
      color: #0d0a14;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .search-bar button:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px var(--philo-shadow);
    }

    .search-results {
      display: none;
      background: var(--philo-card);
      border: 1px solid var(--philo-border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      max-height: 300px;
      overflow-y: auto;
    }

    .search-results.active {
      display: block;
    }

    .search-results .result-item {
      padding: 0.5rem;
      border-bottom: 1px solid var(--philo-border);
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .search-results .result-item:hover {
      background: rgba(155, 107, 255, 0.08);
    }

    .search-results .result-item .titulo {
      color: var(--philo-purple);
      font-weight: 600;
    }

    .search-results .result-item .desc {
      color: var(--philo-muted);
      font-size: 0.8rem;
    }

    .search-results .no-results {
      color: var(--philo-muted);
      text-align: center;
      padding: 1rem;
    }

    /* MENU CIRCULAR */
    .btn-menu-toggle {
      background: none;
      border: none;
      color: var(--philo-purple);
      font-size: 1.8rem;
      cursor: pointer;
      transition: all 0.3s ease;
      padding: 0.3rem 0.6rem;
      border-radius: 8px;
      border: 1px solid transparent;
    }

    .btn-menu-toggle:hover {
      border-color: var(--philo-border);
      background: rgba(155, 107, 255, 0.06);
      transform: scale(1.05);
    }

    .menu-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(8px);
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }

    .menu-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .philo-menu-container {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0.8);
      z-index: 1000;
      transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      opacity: 0;
      pointer-events: none;
    }

    .philo-menu-container.active {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      pointer-events: auto;
    }

    .philo-menu {
      position: relative;
      width: 320px;
      height: 320px;
    }

    .knob {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 80px;
      height: 80px;
      background: radial-gradient(circle at 30% 30%, #2a1a4a, #0d0a14);
      border-radius: 50%;
      border: 2px solid var(--philo-gold);
      box-shadow: 0 0 40px rgba(155, 107, 255, 0.15);
      cursor: pointer;
      z-index: 10;
      display: grid;
      place-items: center;
      font-size: 28px;
      color: var(--philo-gold);
      transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      user-select: none;
    }

    .knob:hover {
      transform: translate(-50%, -50%) scale(1.06);
      box-shadow: 0 0 60px rgba(155, 107, 255, 0.25);
    }

    .knob i {
      transition: transform 0.6s ease;
    }

    .philo-menu.active .knob i {
      transform: rotate(360deg);
    }

    .knob .label {
      position: absolute;
      bottom: -30px;
      font-size: 0.6rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--philo-gold);
      opacity: 0.5;
      white-space: nowrap;
    }

    .philo-menu ul {
      list-style: none;
      width: 100%;
      height: 100%;
      position: relative;
    }

    .philo-menu li {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 60px;
      height: 60px;
      margin: -30px;
      transform: rotate(calc(var(--i) * 72deg)) translate(125px) rotate(calc(var(--i) * -72deg));
      transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      opacity: 0;
      pointer-events: none;
    }

    .philo-menu.active li {
      opacity: 1;
      pointer-events: auto;
    }

    .philo-menu li:nth-child(1) { --i: 0; }
    .philo-menu li:nth-child(2) { --i: 1; }
    .philo-menu li:nth-child(3) { --i: 2; }
    .philo-menu li:nth-child(4) { --i: 3; }
    .philo-menu li:nth-child(5) { --i: 4; }

    .philo-menu li button {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 1.5px solid var(--philo-border);
      background: radial-gradient(circle at 30% 30%, #1a142a, #0d0a14);
      color: var(--philo-cream);
      cursor: pointer;
      font-size: 20px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      display: grid;
      place-items: center;
      position: relative;
    }

    .philo-menu li button:hover {
      transform: scale(1.15);
      border-color: var(--philo-gold);
      box-shadow: 0 0 30px rgba(255, 215, 0, 0.15);
      background: radial-gradient(circle at 30% 30%, #2a1a4a, #0d0a14);
    }

    .philo-menu li button::after {
      content: attr(data-tooltip);
      position: absolute;
      bottom: -28px;
      font-size: 0.55rem;
      letter-spacing: 0.5px;
      color: var(--philo-muted);
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.3s ease;
      font-weight: 600;
    }

    .philo-menu li button:hover::after {
      opacity: 1;
    }

    .menu-close-btn {
      position: absolute;
      top: -20px;
      right: -20px;
      background: rgba(255, 68, 68, 0.12);
      border: 1px solid rgba(255, 68, 68, 0.3);
      color: #ff6b6b;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      z-index: 20;
      display: grid;
      place-items: center;
    }

    .menu-close-btn:hover {
      background: rgba(255, 68, 68, 0.25);
      transform: scale(1.1);
    }

    /* MODULES */
    .modules-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    @media (max-width: 1024px) {
      .modules-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .modules-grid {
        grid-template-columns: 1fr;
      }
      .app-container {
        padding: 1rem;
      }
      .philo-menu {
        width: 260px;
        height: 260px;
      }
      .philo-menu li {
        width: 48px;
        height: 48px;
        margin: -24px;
        transform: rotate(calc(var(--i) * 72deg)) translate(100px) rotate(calc(var(--i) * -72deg));
      }
      .philo-menu li button {
        font-size: 16px;
      }
      .knob {
        width: 64px;
        height: 64px;
        font-size: 22px;
      }
      .menu-close-btn {
        top: -12px;
        right: -12px;
        width: 30px;
        height: 30px;
        font-size: 0.8rem;
      }
      .search-bar {
        max-width: 100%;
      }
    }

    .module-card {
      background: var(--philo-card);
      border: 1px solid var(--philo-border);
      border-radius: 14px;
      padding: 1.6rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .module-card:hover {
      transform: translateY(-6px);
      border-color: var(--philo-gold);
      box-shadow: 0 8px 40px var(--philo-shadow);
    }

    .module-card .card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }

    .module-card .card-header i {
      font-size: 1.6rem;
      color: var(--philo-gold);
    }

    .module-card .card-header h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--philo-cream);
      flex: 1;
    }

    .module-card .card-desc {
      font-size: 0.82rem;
      color: var(--philo-muted);
      line-height: 1.5;
    }

    .badge-new-tag {
      background: rgba(255, 215, 0, 0.15);
      border: 1px solid var(--philo-gold);
      color: var(--philo-gold);
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 1px;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      white-space: nowrap;
    }

    /* MODULE PAGE */
    .modulo-pagina {
      display: none;
      animation: fadeIn 0.4s ease both;
    }

    .modulo-pagina.active {
      display: block;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .btn-voltar {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--philo-border);
      color: var(--philo-muted);
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-bottom: 1.5rem;
    }

    .btn-voltar:hover {
      background: rgba(255, 255, 255, 0.12);
      color: var(--philo-cream);
      transform: translateX(-3px);
    }

    .modulo-container {
      background: var(--philo-card);
      border: 1px solid var(--philo-border);
      border-radius: 14px;
      padding: 1.6rem;
    }

    .modulo-container .card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.8rem;
    }

    .modulo-container .card-header i {
      font-size: 1.8rem;
      color: var(--philo-gold);
    }

    .modulo-container .card-header h2 {
      font-size: 1.2rem;
      color: var(--philo-purple);
    }

    /* TABS */
    .inner-tabs {
      display: flex;
      gap: 0.4rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .tab-btn {
      padding: 0.35rem 0.8rem;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--philo-border);
      border-radius: 999px;
      color: var(--philo-muted);
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .tab-btn.active,
    .tab-btn:hover {
      background: var(--philo-purple);
      border-color: var(--philo-purple);
      color: #0d0a14;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
      animation: fadeIn 0.25s ease both;
    }

    /* APONTAMENTOS */
    .philo-apontamento {
      background: rgba(155, 107, 255, 0.06);
      border-left: 4px solid var(--philo-purple);
      padding: 1.2rem;
      border-radius: 0 8px 8px 0;
      margin-bottom: 1.2rem;
    }

    .philo-apontamento h4 {
      color: var(--philo-gold);
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .philo-apontamento p,
    .philo-apontamento li {
      color: var(--philo-cream);
      font-size: 0.85rem;
      line-height: 1.7;
    }

    .philo-apontamento ul {
      padding-left: 1.5rem;
    }

    .philo-apontamento .destaque {
      color: var(--philo-gold);
      font-weight: 600;
    }

    .tabela-comparativa {
      width: 100%;
      border-collapse: collapse;
      margin: 0.5rem 0;
      font-size: 0.82rem;
    }

    .tabela-comparativa th,
    .tabela-comparativa td {
      border: 1px solid var(--philo-border);
      padding: 0.5rem 0.8rem;
      text-align: left;
    }

    .tabela-comparativa th {
      background: rgba(155, 107, 255, 0.15);
      color: var(--philo-gold);
      font-weight: 700;
    }

    .tabela-comparativa td {
      color: var(--philo-cream);
    }

    /* EXERCÍCIOS */
    .philo-exercicio {
      background: rgba(155, 107, 255, 0.04);
      border: 1px solid var(--philo-border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 0.8rem;
    }

    .philo-exercicio .pergunta {
      color: var(--philo-gold);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .philo-exercicio .opcoes {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .philo-exercicio .opcoes label {
      color: var(--philo-cream);
      font-size: 0.85rem;
      cursor: pointer;
    }

    .philo-exercicio .opcoes input[type="radio"] {
      accent-color: var(--philo-purple);
      margin-right: 0.5rem;
    }

    .btn-verificar {
      margin-top: 0.7rem;
      padding: 0.4rem 1rem;
      background: var(--philo-purple);
      border: none;
      border-radius: 8px;
      color: #0d0a14;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-verificar:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px var(--philo-shadow);
    }

    .resposta-feedback {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .resposta-feedback.correto {
      color: var(--philo-gold);
    }
    .resposta-feedback.errado {
      color: var(--philo-error);
    }

    /* SOLUÇÕES */
    .philo-solucao {
      background: rgba(155, 107, 255, 0.05);
      border: 1px dashed var(--philo-border);
      border-radius: 8px;
      padding: 0.8rem 1rem;
      margin-top: 0.5rem;
    }

    .philo-solucao .solucao-titulo {
      color: var(--philo-gold);
      font-weight: 700;
      font-size: 0.8rem;
      margin-bottom: 0.3rem;
    }

    .philo-solucao .solucao-texto {
      color: var(--philo-cream);
      font-size: 0.82rem;
    }

    /* FLASHCARDS */
    .philo-flashcard {
      perspective: 800px;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
      cursor: pointer;
    }

    .philo-flashcard .card-inner {
      position: relative;
      width: 100%;
      min-height: 160px;
      transition: transform 0.6s;
      transform-style: preserve-3d;
    }

    .philo-flashcard .card-inner.flipped {
      transform: rotateY(180deg);
    }

    .philo-flashcard .card-front,
    .philo-flashcard .card-back {
      position: absolute;
      width: 100%;
      min-height: 160px;
      backface-visibility: hidden;
      border-radius: 8px;
      padding: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .philo-flashcard .card-front {
      background: var(--philo-card);
      border: 1px solid var(--philo-border);
      color: var(--philo-cream);
    }

    .philo-flashcard .card-back {
      background: var(--philo-purple);
      color: #0d0a14;
      transform: rotateY(180deg);
      font-weight: 600;
    }

    .flashcard-counter {
      text-align: center;
      font-size: 0.75rem;
      color: var(--philo-muted);
      margin-top: 0.8rem;
    }

    .flashcard-nav {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin-top: 0.5rem;
    }

    .flashcard-nav button {
      padding: 0.3rem 0.8rem;
      background: rgba(155, 107, 255, 0.15);
      border: 1px solid var(--philo-border);
      border-radius: 8px;
      color: var(--philo-cream);
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .flashcard-nav button:hover {
      background: rgba(155, 107, 255, 0.3);
      border-color: var(--philo-purple);
    }

    /* TIMELINE */
    .philo-timeline {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: 0.5rem 0;
    }

    .philo-timeline .evento {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 0.8rem;
      background: rgba(155, 107, 255, 0.04);
      border-radius: 8px;
      border-left: 3px solid var(--philo-gold);
    }

    .philo-timeline .evento .ano {
      font-weight: 800;
      color: var(--philo-gold);
      min-width: 80px;
      font-size: 0.9rem;
    }

    .philo-timeline .evento .desc {
      color: var(--philo-cream);
      font-size: 0.85rem;
      line-height: 1.5;
    }

    /* MAPA CONCEPTUAL */
    .mapa-conceptual {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 1rem;
      background: rgba(155, 107, 255, 0.03);
      border-radius: 12px;
      border: 1px solid var(--philo-border);
    }

    .mapa-nodo {
      background: var(--philo-card);
      border: 2px solid var(--philo-purple);
      border-radius: 12px;
      padding: 0.8rem 1.5rem;
      margin: 0.3rem 0;
      color: var(--philo-cream);
      font-weight: 600;
      font-size: 0.9rem;
      text-align: center;
      min-width: 120px;
      transition: all 0.3s ease;
    }

    .mapa-nodo:hover {
      border-color: var(--philo-gold);
