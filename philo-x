  <script>
    (function() {
      console.log('🧠 Boot PHILO-X iniciado');
      var bootScreen = document.getElementById('boot-screen');
      var statusEl = document.getElementById('boot-status');
      if (!bootScreen || !statusEl) {
        console.error('❌ Elementos do boot não encontrados');
        return;
      }

      var canvas = document.getElementById('particles-canvas');
      var ctx = canvas.getContext('2d');
      var width, height;

      var symbols = ['🧠', '💭', '📜', '⚖️', '🏛️', '🌍', '🗺️', '🔍', '💡', '✨', '🌟', '📚', '✍️', '🕊️', '🔮', '🌿', '🫂', '🤝', '🗣️',
        '📖', '🧘', '🌱', '🪷', '☯️', '🕯️', '📿', '🧿', '⚛️', '🧬', '🔭', '🧪', '📐'
      ];

      function resizeCanvas() {
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = width;
        canvas.height = height;
      }
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      var particles = [];
      var NUM_PARTICLES = 160;

      function randomColor() {
        var colors = ['#9b6bff', '#ffd700', '#f0ecf5', '#8a7a9a', '#7c3aed', '#c084fc', '#fbbf24'];
        return colors[Math.floor(Math.random() * colors.length)];
      }

      function createParticle() {
        return {
          x: Math.random() * width,
          y: Math.random() * height,
          size: 18 + Math.random() * 20,
          speedX: (Math.random() - 0.5) * 0.3,
          speedY: (Math.random() - 0.5) * 0.3,
          symbol: symbols[Math.floor(Math.random() * symbols.length)],
          color: randomColor(),
          rotation: Math.random() * Math.PI * 2,
          rotationSpeed: (Math.random() - 0.5) * 0.02,
          opacity: 0.04 + Math.random() * 0.04,
          life: 0,
          maxLife: 250 + Math.random() * 350
        };
      }
      for (var i = 0; i < NUM_PARTICLES; i++) particles.push(createParticle());

      function animateParticles() {
        ctx.clearRect(0, 0, width, height);
        for (var i = 0; i < particles.length; i++) {
          var p = particles[i];
          p.x += p.speedX;
          p.y += p.speedY;
          p.rotation += p.rotationSpeed;
          p.life++;
          if (p.x < -50 || p.x > width + 50 || p.y < -50 || p.y > height + 50 || p.life > p.maxLife) {
            particles[i] = createParticle();
            particles[i].life = 0;
          }
          p.speedX += (Math.random() - 0.5) * 0.01;
          p.speedY += (Math.random() - 0.5) * 0.01;
          p.speedX = Math.max(-0.8, Math.min(0.8, p.speedX));
          p.speedY = Math.max(-0.8, Math.min(0.8, p.speedY));
          var alpha = p.opacity * (1 - p.life / p.maxLife);
          ctx.save();
          ctx.translate(p.x, p.y);
          ctx.rotate(p.rotation);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = Math.max(0.01, alpha);
          ctx.font = p.size + 'px "Segoe UI Emoji", "Apple Color Emoji", sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(p.symbol, 0, 0);
          ctx.restore();
        }
        requestAnimationFrame(animateParticles);
      }
      animateParticles();

      var bootMessages = ['Inicializando...', 'Carregando módulos...', 'Configurando interface...',
        'Conectando ao servidor...', 'PHILO-X pronto!', 'Powered by M4L!K 🚀'
      ];
      var index = 0;
      var messageInterval = setInterval(function() {
        index++;
        if (index < bootMessages.length) {
          statusEl.textContent = bootMessages[index];
        } else {
          clearInterval(messageInterval);
        }
      }, 400);

      setTimeout(function() {
        bootScreen.classList.add('hidden');
        setTimeout(function() {
          bootScreen.style.display = 'none';
        }, 800);
      }, 4500);
      setTimeout(function() {
        if (!bootScreen.classList.contains('hidden')) {
          bootScreen.classList.add('hidden');
          setTimeout(function() {
            bootScreen.style.display = 'none';
          }, 800);
        }
      }, 7000);
      console.log('✅ Boot PHILO-X carregado com sucesso');
    })();
  </script>

