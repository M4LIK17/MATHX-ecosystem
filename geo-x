<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GEO-X — Geografia Interativa</title>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    /* ═══════════════════════════════════════════
       GEO-X — ESTILOS COMPLETOS (sem globo 3D)
    ═══════════════════════════════════════════ */

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0a120a;
      color: #e8f0e8;
      min-height: 100vh;
      overflow-x: hidden;
      transition: background 0.3s ease, color 0.3s ease;
    }

    :root {
      --geo-bg: #0a120a;
      --geo-card: #111e11;
      --geo-border: #1e3a1e;
      --geo-green: #4CAF50;
      --geo-forest: #2E7D32;
      --geo-earth: #8B7D6B;
      --geo-sky: #64B5F6;
      --geo-water: #1E88E5;
      --geo-sand: #D4A373;
      --geo-cream: #e8f0e8;
      --geo-muted: #5a7a5a;
      --geo-dark: #0a120a;
      --geo-shadow: rgba(76, 175, 80, 0.2);
    }

    body.light-mode {
      --geo-bg: #f0f5f0;
      --geo-card: #ffffff;
      --geo-border: #c8dcc8;
      --geo-cream: #1a2a1a;
      --geo-muted: #6a8a6a;
      --geo-shadow: rgba(0, 0, 0, 0.08);
    }

    ::-webkit-scrollbar {
      width: 6px;
      background: var(--geo-bg);
    }
    ::-webkit-scrollbar-thumb {
      background: var(--geo-border);
      border-radius: 999px;
    }

    .app-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 2rem 4rem;
      position: relative;
      min-height: 100vh;
    }

    /* HEADER */
    .geo-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 0 1.5rem;
      border-bottom: 2px solid var(--geo-border);
      margin-bottom: 2rem;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .geo-header-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .geo-header-left i {
      font-size: 2.2rem;
      color: var(--geo-sand);
    }

    .geo-header-left h1 {
      font-size: 1.8rem;
      color: var(--geo-green);
      font-weight: 700;
      letter-spacing: 1px;
    }

    .geo-header-left h1 span {
      color: var(--geo-sand);
    }

    .geo-header .badge {
      background: var(--geo-border);
      color: var(--geo-sky);
      padding: 0.2rem 0.8rem;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    .header-actions button {
      background: none;
      border: none;
      color: var(--geo-cream);
      font-size: 1.2rem;
      cursor: pointer;
      padding: 0.4rem;
      border-radius: 8px;
      transition: all 0.3s ease;
      border: 1px solid transparent;
    }

    .header-actions button:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--geo-border);
    }

    /* SEARCH */
    .search-bar {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      max-width: 500px;
    }

    .search-bar input {
      flex: 1;
      padding: 0.6rem 1rem;
      border-radius: 8px;
      border: 1px solid var(--geo-border);
      background: var(--geo-card);
      color: var(--geo-cream);
      font-size: 0.9rem;
      outline: none;
      transition: border-color 0.3s ease;
    }

    .search-bar input:focus {
      border-color: var(--geo-green);
    }

    .search-bar input::placeholder {
      color: var(--geo-muted);
    }

    .search-bar button {
      padding: 0.6rem 1.2rem;
      background: var(--geo-green);
      border: none;
      border-radius: 8px;
      color: #0a120a;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .search-bar button:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px var(--geo-shadow);
    }

    .search-results {
      display: none;
      background: var(--geo-card);
      border: 1px solid var(--geo-border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1rem;
      max-height: 300px;
      overflow-y: auto;
    }

    .search-results.active {
      display: block;
    }

    .search-results .result-item {
      padding: 0.5rem;
      border-bottom: 1px solid var(--geo-border);
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .search-results .result-item:hover {
      background: rgba(76, 175, 80, 0.08);
    }

    .search-results .result-item .titulo {
      color: var(--geo-green);
      font-weight: 600;
    }

    .search-results .result-item .desc {
      color: var(--geo-muted);
      font-size: 0.8rem;
    }

    .search-results .no-results {
      color: var(--geo-muted);
      text-align: center;
      padding: 1rem;
    }

    /* MENU CIRCULAR */
    .btn-menu-toggle {
      background: none;
      border: none;
      color: var(--geo-green);
      font-size: 1.8rem;
      cursor: pointer;
      transition: all 0.3s ease;
      padding: 0.3rem 0.6rem;
      border-radius: 8px;
      border: 1px solid transparent;
    }

    .btn-menu-toggle:hover {
      border-color: var(--geo-border);
      background: rgba(76, 175, 80, 0.06);
      transform: scale(1.05);
    }

    .menu-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(8px);
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s ease;
    }

    .menu-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .geo-menu-container {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0.8);
      z-index: 1000;
      transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      opacity: 0;
      pointer-events: none;
    }

    .geo-menu-container.active {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      pointer-events: auto;
    }

    .geo-menu {
      position: relative;
      width: 320px;
      height: 320px;
    }

    .knob {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 80px;
      height: 80px;
      background: radial-gradient(circle at 30% 30%, #1a3a1a, #0d1f0d);
      border-radius: 50%;
      border: 2px solid var(--geo-green);
      box-shadow: 0 0 40px rgba(76, 175, 80, 0.15);
      cursor: pointer;
      z-index: 10;
      display: grid;
      place-items: center;
      font-size: 28px;
      color: var(--geo-green);
      transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      user-select: none;
    }

    .knob:hover {
      transform: translate(-50%, -50%) scale(1.06);
      box-shadow: 0 0 60px rgba(76, 175, 80, 0.25);
    }

    .knob i {
      transition: transform 0.6s ease;
    }

    .geo-menu.active .knob i {
      transform: rotate(360deg);
    }

    .knob .label {
      position: absolute;
      bottom: -30px;
      font-size: 0.6rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--geo-green);
      opacity: 0.5;
      white-space: nowrap;
    }

    .geo-menu ul {
      list-style: none;
      width: 100%;
      height: 100%;
      position: relative;
    }

    .geo-menu li {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 60px;
      height: 60px;
      margin: -30px;
      transform: rotate(calc(var(--i) * 60deg)) translate(125px) rotate(calc(var(--i) * -60deg));
      transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      opacity: 0;
      pointer-events: none;
    }

    .geo-menu.active li {
      opacity: 1;
      pointer-events: auto;
    }

    .geo-menu li:nth-child(1) { --i: 0; }
    .geo-menu li:nth-child(2) { --i: 1; }
    .geo-menu li:nth-child(3) { --i: 2; }
    .geo-menu li:nth-child(4) { --i: 3; }
    .geo-menu li:nth-child(5) { --i: 4; }
    .geo-menu li:nth-child(6) { --i: 5; }
    .geo-menu li:nth-child(7) { --i: 6; }

    .geo-menu li button {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      border: 1.5px solid var(--geo-border);
      background: radial-gradient(circle at 30% 30%, #162016, #0d1f0d);
      color: var(--geo-cream);
      cursor: pointer;
      font-size: 22px;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
      display: grid;
      place-items: center;
      position: relative;
    }

    .geo-menu li button:hover {
      transform: scale(1.15);
      border-color: var(--geo-green);
      box-shadow: 0 0 30px rgba(76, 175, 80, 0.2);
      background: radial-gradient(circle at 30% 30%, #1e3a1e, #0d1f0d);
    }

    .geo-menu li button::after {
      content: attr(data-tooltip);
      position: absolute;
      bottom: -28px;
      font-size: 0.55rem;
      letter-spacing: 0.5px;
      color: var(--geo-muted);
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.3s ease;
      font-weight: 600;
    }

    .geo-menu li button:hover::after {
      opacity: 1;
    }

    .geo-menu li:last-child button {
      border-color: var(--geo-sand);
      color: var(--geo-sand);
    }

    .geo-menu li:last-child button:hover {
      border-color: var(--geo-sand);
      box-shadow: 0 0 30px rgba(212, 163, 115, 0.2);
    }

    .menu-close-btn {
      position: absolute;
      top: -20px;
      right: -20px;
      background: rgba(255, 68, 68, 0.12);
      border: 1px solid rgba(255, 68, 68, 0.3);
      color: #ff6b6b;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      z-index: 20;
      display: grid;
      place-items: center;
    }

    .menu-close-btn:hover {
      background: rgba(255, 68, 68, 0.25);
      transform: scale(1.1);
    }

    /* MODULES */
    .modules-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    @media (max-width: 1024px) {
      .modules-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .modules-grid {
        grid-template-columns: 1fr;
      }
      .app-container {
        padding: 1rem;
      }
      .geo-menu {
        width: 260px;
        height: 260px;
      }
      .geo-menu li {
        width: 48px;
        height: 48px;
        margin: -24px;
        transform: rotate(calc(var(--i) * 60deg)) translate(100px) rotate(calc(var(--i) * -60deg));
      }
      .geo-menu li button {
        font-size: 18px;
      }
      .knob {
        width: 64px;
        height: 64px;
        font-size: 22px;
      }
      .menu-close-btn {
        top: -12px;
        right: -12px;
        width: 30px;
        height: 30px;
        font-size: 0.8rem;
      }
      .search-bar {
        max-width: 100%;
      }
    }

    .module-card {
      background: var(--geo-card);
      border: 1px solid var(--geo-border);
      border-radius: 14px;
      padding: 1.6rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .module-card:hover {
      transform: translateY(-6px);
      border-color: var(--geo-green);
      box-shadow: 0 8px 40px var(--geo-shadow);
    }

    .module-card .card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }

    .module-card .card-header i {
      font-size: 1.6rem;
      color: var(--geo-sand);
    }

    .module-card .card-header h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--geo-cream);
      flex: 1;
    }

    .module-card .card-desc {
      font-size: 0.82rem;
      color: var(--geo-muted);
      line-height: 1.5;
    }

    .badge-new-tag {
      background: rgba(76, 175, 80, 0.2);
      border: 1px solid var(--geo-green);
      color: var(--geo-green);
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 1px;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
      white-space: nowrap;
    }

    /* MODULE PAGE */
    .modulo-pagina {
      display: none;
      animation: fadeIn 0.4s ease both;
    }

    .modulo-pagina.active {
      display: block;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .btn-voltar {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--geo-border);
      color: var(--geo-muted);
      padding: 0.5rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      margin-bottom: 1.5rem;
    }

    .btn-voltar:hover {
      background: rgba(255, 255, 255, 0.12);
      color: var(--geo-cream);
      transform: translateX(-3px);
    }

    .modulo-container {
      background: var(--geo-card);
      border: 1px solid var(--geo-border);
      border-radius: 14px;
      padding: 1.6rem;
    }

    .modulo-container .card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.8rem;
    }

    .modulo-container .card-header i {
      font-size: 1.8rem;
      color: var(--geo-sand);
    }

    .modulo-container .card-header h2 {
      font-size: 1.2rem;
      color: var(--geo-green);
    }

    /* TABS */
    .inner-tabs {
      display: flex;
      gap: 0.4rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .tab-btn {
      padding: 0.35rem 0.8rem;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--geo-border);
      border-radius: 999px;
      color: var(--geo-muted);
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .tab-btn.active,
    .tab-btn:hover {
      background: var(--geo-green);
      border-color: var(--geo-green);
      color: #0a120a;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
      animation: fadeIn 0.25s ease both;
    }

    /* SÍNTESE */
    .geo-sintese {
      background: rgba(76, 175, 80, 0.06);
      border-left: 4px solid var(--geo-green);
      padding: 1.2rem;
      border-radius: 0 8px 8px 0;
      margin-bottom: 1.2rem;
    }

    .geo-sintese h4 {
      color: var(--geo-green);
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
    }

    .geo-sintese p,
    .geo-sintese li {
      color: var(--geo-cream);
      font-size: 0.85rem;
      line-height: 1.7;
    }

    .geo-sintese ul {
      padding-left: 1.5rem;
    }

    /* EXERCÍCIOS */
    .geo-exercicio {
      background: rgba(76, 175, 80, 0.04);
      border: 1px solid var(--geo-border);
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 0.8rem;
    }

    .geo-exercicio .pergunta {
      color: var(--geo-sky);
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .geo-exercicio .opcoes {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .geo-exercicio .opcoes label {
      color: var(--geo-cream);
      font-size: 0.85rem;
      cursor: pointer;
    }

    .geo-exercicio .opcoes input[type="radio"] {
      accent-color: var(--geo-green);
      margin-right: 0.5rem;
    }

    .btn-verificar {
      margin-top: 0.7rem;
      padding: 0.4rem 1rem;
      background: var(--geo-green);
      border: none;
      border-radius: 8px;
      color: #0a120a;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-verificar:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px var(--geo-shadow);
    }

    .resposta-feedback {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .resposta-feedback.correto {
      color: var(--geo-green);
    }
    .resposta-feedback.errado {
      color: #ff6b6b;
    }

    /* SOLUÇÕES */
    .geo-solucao {
      background: rgba(76, 175, 80, 0.05);
      border: 1px dashed var(--geo-border);
      border-radius: 8px;
      padding: 0.8rem 1rem;
      margin-top: 0.5rem;
    }

    .geo-solucao .solucao-titulo {
      color: var(--geo-sand);
      font-weight: 700;
      font-size: 0.8rem;
      margin-bottom: 0.3rem;
    }

    .geo-solucao .solucao-texto {
      color: var(--geo-cream);
      font-size: 0.82rem;
    }

    /* QUIZ */
    .btn-quiz-iniciar {
      padding: 0.6rem 1.5rem;
      background: var(--geo-green);
      border: none;
      border-radius: 8px;
      color: #0a120a;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-quiz-iniciar:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px var(--geo-shadow);
    }

    .btn-quiz-cancelar {
      padding: 0.6rem 1.5rem;
      background: rgba(255, 68, 68, 0.12);
      border: 1px solid rgba(255, 68, 68, 0.3);
      border-radius: 8px;
      color: #ff6b6b;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.3s ease;
      display: none;
    }

    .btn-quiz-cancelar:hover {
      background: rgba(255, 68, 68, 0.22);
    }

    /* FLASHCARDS */
    .geo-flashcard {
      perspective: 800px;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
      cursor: pointer;
    }

    .geo-flashcard .card-inner {
      position: relative;
      width: 100%;
      min-height: 160px;
      transition: transform 0.6s;
      transform-style: preserve-3d;
    }

    .geo-flashcard .card-inner.flipped {
      transform: rotateY(180deg);
    }

    .geo-flashcard .card-front,
    .geo-flashcard .card-back {
      position: absolute;
      width: 100%;
      min-height: 160px;
      backface-visibility: hidden;
      border-radius: 8px;
      padding: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .geo-flashcard .card-front {
      background: var(--geo-card);
      border: 1px solid var(--geo-border);
      color: var(--geo-cream);
    }

    .geo-flashcard .card-back {
      background: var(--geo-green);
      color: #0a120a;
      transform: rotateY(180deg);
      font-weight: 600;
    }

    .flashcard-counter {
      text-align: center;
      font-size: 0.75rem;
      color: var(--geo-muted);
      margin-top: 0.8rem;
    }

    .flashcard-nav {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin-top: 0.5rem;
    }

    .flashcard-nav button {
      padding: 0.3rem 0.8rem;
      background: rgba(76, 175, 80, 0.15);
      border: 1px solid var(--geo-border);
      border-radius: 8px;
      color: var(--geo-cream);
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
    }

    .flashcard-nav button:hover {
      background: rgba(76, 175, 80, 0.3);
      border-color: var(--geo-green);
    }

    /* TIMELINE */
    .geo-timeline {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      padding: 0.5rem 0;
    }

    .geo-timeline .evento {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 0.8rem;
      background: rgba(76, 175, 80, 0.04);
      border-radius: 8px;
      border-left: 3px solid var(--geo-green);
    }

    .geo-timeline .evento .ano {
      font-weight: 800;
      color: var(--geo-sand);
      min-width: 80px;
      font-size: 0.9rem;
    }

    .geo-timeline .evento .desc {
      color: var(--geo-cream);
      font-size: 0.85rem;
      line-height: 1.5;
    }

    /* MAPA (alternativa sem Leaflet) */
    .geo-mapa-container {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--geo-border);
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      max-width: 600px;
      margin: 0 auto;
    }

    .geo-mapa-container i {
      font-size: 3rem;
      color: var(--geo-sand);
      margin-bottom: 0.5rem;
