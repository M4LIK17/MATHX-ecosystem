  <script>
    // ============================================================
    //  MENU CIRCULAR — VERSÃO CORRIGIDA
    // ============================================================

    document.addEventListener('DOMContentLoaded', function() {

      // Menu circular
      const menuToggleBtn = document.getElementById('menuToggleBtn');
      const menuCloseBtn = document.getElementById('menuCloseBtn');
      const menuOverlay = document.getElementById('menuOverlay');
      const menuContainer = document.getElementById('menuContainer');
      const menuKnob = document.getElementById('menuKnob');
      const geoMenu = document.getElementById('geoMenu');

      function abrirMenu() {
        menuOverlay.classList.add('active');
        menuContainer.classList.add('active');
        geoMenu.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function fecharMenu() {
        menuOverlay.classList.remove('active');
        menuContainer.classList.remove('active');
        geoMenu.classList.remove('active');
        document.body.style.overflow = '';
      }

      if (menuToggleBtn) {
        menuToggleBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          if (menuContainer.classList.contains('active')) {
            fecharMenu();
          } else {
            abrirMenu();
          }
        });
      }

      if (menuCloseBtn) {
        menuCloseBtn.addEventListener('click', fecharMenu);
      }

      if (menuOverlay) {
        menuOverlay.addEventListener('click', fecharMenu);
      }

      if (menuKnob) {
        menuKnob.addEventListener('click', function(e) {
          e.stopPropagation();
          geoMenu.classList.toggle('active');
        });
      }

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          fecharMenu();
        }
      });

      document.querySelectorAll('.geo-menu li button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTimeout(fecharMenu, 300);
        });
      });

      // Tema
      let temaEscuro = true;

      window.toggleTheme = function() {
        temaEscuro = !temaEscuro;
        document.body.classList.toggle('light-mode', !temaEscuro);
        const icon = document.querySelector('#themeToggle i');
        if (temaEscuro) {
          icon.className = 'fas fa-moon';
        } else {
          icon.className = 'fas fa-sun';
        }
      };

      // Voltar MATHX
      window.voltarMathX = function() {
        window.location.href = 'index.html';
      };

      // Voltar lista
      window.voltarLista = function() {
        document.getElementById('modulo-lista').style.display = 'block';
        document.getElementById('modulo-pagina').classList.remove('active');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      // Abrir módulo
      window.abrirModulo = function(id) {
        const lista = document.getElementById('modulo-lista');
        const pagina = document.getElementById('modulo-pagina');
        const conteudo = document.getElementById('modulo-conteudo');

        lista.style.display = 'none';
        pagina.classList.add('active');

        switch (id) {
          case 'unidade1':
            conteudo.innerHTML = renderUnidade1();
            break;
          case 'unidade2':
            conteudo.innerHTML = renderUnidade2();
            break;
          case 'unidade3':
            conteudo.innerHTML = renderUnidade3();
            break;
          case 'unidade4':
            conteudo.innerHTML = renderUnidade4();
            break;
          case 'unidade5':
            conteudo.innerHTML = renderUnidade5();
            break;
          case 'unidade6':
            conteudo.innerHTML = renderUnidade6();
            break;
          default:
            conteudo.innerHTML =
              '<div class="modulo-container"><h3 style="color:var(--geo-green);">Unidade em desenvolvimento</h3><p style="color:var(--geo-muted);">Brevemente disponível.</p></div>';
        }

        const primeiroTab = document.querySelector('.tab-btn.active');
        if (primeiroTab) {
          const targetId = primeiroTab.dataset.target;
          document.querySelectorAll('.tab-content').forEach(function(t) { t.classList.remove('active'); });
          const target = document.getElementById(targetId);
          if (target) target.classList.add('active');
        }

        setTimeout(function() {
          if (document.getElementById('geo-flashcard-front')) {
            carregarFlashcardGeo(0);
          }
        }, 100);

        window.scrollTo({ top: 0, behavior: 'smooth' });
      };

      // Switch Tab
      window.switchTab = function(btn, targetId) {
        const parent = btn.closest('.inner-tabs');
        if (!parent) return;
        parent.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        const container = btn.closest('.modulo-container');
        if (container) {
          container.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
