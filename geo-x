      const searchIndex = [];

      function buildSearchIndex() {
        var modules = [
          { id: 'unidade1', titulo: 'População', desc: 'Distribuição, crescimento, migrações, teorias demográficas' },
          { id: 'unidade2', titulo: 'Agricultura e Pecuária', desc: 'Evolução, espaço agrário, sistemas agrários' },
          { id: 'unidade3', titulo: 'Indústria e Comércio', desc: 'Revolução Industrial, tipos de indústria' },
          { id: 'unidade4', titulo: 'Turismo', desc: 'Conceito, tipos, importância, património' },
          { id: 'unidade5', titulo: 'Transportes e Comunicações', desc: 'Evolução, tipos de transporte' },
          { id: 'unidade6', titulo: 'Urbanismo', desc: 'Conceito de cidade, evolução, problemas urbanos' }
        ];

        var sinteses = [
          'Distribuição da população, áreas de grande concentração, vazios humanos',
          'Crescimento populacional, natalidade, fecundidade, mortalidade',
          'Migrações, temporárias, definitivas, internas, externas',
          'Teorias demográficas, Malthusiana, Anti malthusiana',
          'Estrutura da população, pirâmides etárias, sectores de actividade',
          'Problemas demográficos, desigualdades, desemprego',
          'Evolução da agricultura, Revolução Neolítica, sedentarização',
          'Espaço agrário, factores naturais e humanos',
          'Sistemas agrários, tradicional, moderna, sequeiro, irrigada',
          'Pecuária, extensiva, intensiva, regiões produtoras',
          'Problemas ambientais, degradação dos solos, queimadas',
          'Evolução da indústria, artesanal, manufactureira, Revolução Industrial',
          'Fases da Revolução Industrial, máquina a vapor, petróleo, automação',
          'Tipos de indústria, bens de equipamento, bens de consumo, indústrias de ponta',
          'Comércio internacional, desigualdades, fluxos comerciais',
          'Conceito de turismo, tipos, cultural, desportivo, religioso, ambiental',
          'Importância do turismo, rendimentos, divisas, receitas fiscais',
          'Património turístico mundial, natural, cultural, bacias turísticas',
          'Impactos ambientais do turismo, positivos, negativos',
          'Evolução dos transportes, máquina a vapor, diesel, automóvel, avião',
          'Tipos de transporte, rodoviário, ferroviário, marítimo, aéreo',
          'Comunicações, evolução, rádio, televisão, internet',
          'Impacto ambiental dos transportes, poluição atmosférica',
          'Conceito de cidade, características, concentração de habitat',
          'Evolução das cidades, Jericó, Idade Média, Revolução Industrial',
          'Funções da cidade, político-administrativa, industrial, comercial, cultural, religiosa',
          'Relações cidade-campo, interdependência',
          'Problemas urbanos, trânsito, abastecimento, poluição, saturação demográfica'
        ];

        searchIndex.length = 0;
        modules.forEach(function(m) {
          searchIndex.push({ ...m, tipo: 'modulo' });
        });
        sinteses.forEach(function(texto, i) {
          var moduloId = 'unidade1';
          if (i >= 6 && i < 11) moduloId = 'unidade2';
          else if (i >= 11 && i < 15) moduloId = 'unidade3';
          else if (i >= 15 && i < 19) moduloId = 'unidade4';
          else if (i >= 19 && i < 23) moduloId = 'unidade5';
          else if (i >= 23) moduloId = 'unidade6';
          var modulo = modules.find(function(m) { return m.id === moduloId; });
          searchIndex.push({
            id: moduloId,
            titulo: modulo ? modulo.titulo : 'Unidade',
            desc: texto,
            tipo: 'sintese',
            texto: texto
          });
        });
      }

      window.buscarConteudo = function(event) {
        var input = document.getElementById('searchInput');
        var results = document.getElementById('searchResults');
        var query = input.value.toLowerCase().trim();

        if (event && event.key === 'Enter') {
          event.preventDefault();
        }

        if (query.length < 2) {
          results.classList.remove('active');
          return;
        }

        buildSearchIndex();

        var resultados = searchIndex.filter(function(item) {
          return item.titulo.toLowerCase().includes(query) ||
            item.desc.toLowerCase().includes(query);
        });

        if (resultados.length === 0) {
          results.innerHTML = '<div class="no-results">Nenhum resultado encontrado para "' + query + '"</div>';
          results.classList.add('active');
          return;
        }

        results.innerHTML = resultados.slice(0, 10).map(function(item) {
          return '<div class="result-item" onclick="abrirModulo(\'' + item.id + '\')">' +
            '<div class="titulo">' + (item.tipo === 'modulo' ? '📚' : '📖') + ' ' + item.titulo + '</div>' +
            '<div class="desc">' + item.desc.substring(0, 100) + (item.desc.length > 100 ? '...' : '') + '</div>' +
            '</div>';
        }).join('');

        results.classList.add('active');
      };

      // Inicializar
      document.getElementById('modulo-lista').style.display = 'block';
      document.getElementById('modulo-pagina').classList.remove('active');

      // Carregar flashcards
      geoFlashcards = geoFlashcardsData;
      setTimeout(function() {
        if (document.getElementById('geo-flashcard-front')) {
          carregarFlashcardGeo(0);
        }
      }, 200);

      console.log('🌍 GEO-X carregado com sucesso!');
    });
